# Neon Postgres connection string used by Drizzle and runtime database access.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"
DATABASE_URL=""

# DeepSeek is optional in local development. Without this key, chat returns a
# local fallback reply after loading the active personal agent prompt.
DEEPSEEK_API_KEY=""

# Default model used by services/ai/deepseek.ts.
DEEPSEEK_MODEL="deepseek-v4-flash"
